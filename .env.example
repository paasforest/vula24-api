# PostgreSQL (Railway plugin or external)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Server
PORT=3000
NODE_ENV=development

# Required for locksmith email/password login (use a long random string in production)
JWT_SECRET=replace-with-long-random-string

# Comma-separated origins for browser CORS, or * for allow-all (Next.js proxies do not require CORS)
CORS_ORIGIN=*

# SMSPortal (https://smsportal.com) — REST Basic auth; required for approval / activation SMS
SMSPORTAL_CLIENT_ID=
SMSPORTAL_CLIENT_SECRET=

# Founding / launch: no R499/R899 in approval SMS; activate expects R0; expiry = N months (default 6); cron SMS is soft
# LAUNCH_FREE_PLATFORM=true
# FOUNDING_FREE_MONTHS=6
# FIRST_PLATFORM_BILLING_MONTH=November 2026

# Alert when approval SMS fails (same number as job no-coverage alerts)
# ADMIN_PHONE=27821234567

# Optional: set to 1 while debugging SMS responses in server logs
# SMS_DEBUG=1

# Public site URL used in SMS links (Railway: set to your Vercel URL)
# NEXT_PUBLIC_APP_URL=https://vula24.co.za

# Cloudinary — proof-of-payment uploads (JPEG, PNG, WEBP, PDF up to 5 MB)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: Resend (https://resend.com) — password-reset emails (SMS also sent to locksmith phone)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@your-verified-domain.com
